# Gemini AI API Key(s) — comma-separated for failover
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection String
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/yourdb

# Shopify Storefront API
SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token

# Redis (optional — falls back to in-memory cache)
REDIS_URL=

# Internal secret for manual catalog refresh
INTERNAL_REFRESH_SECRET=sync-secret-123

# AWS S3 Configuration
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Frontend URL (for CORS)
FRONTEND_URL=https://your-amplify-app.amplifyapp.com

# Port (local dev only — Lambda ignores this)
PORT=5000
